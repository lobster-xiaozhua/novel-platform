# ===== Database =====
# 对应 config.json → database
DATABASE_URL=postgresql://novel:novel123@localhost:5432/novel_platform

# ===== Redis =====
# 对应 config.json → redis
REDIS_URL=redis://localhost:6379

# ===== Meilisearch =====
# 对应 config.json → meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili_master_key_change_me

# ===== JWT =====
# 对应 config.json → jwt
# ⚠️ 生产环境务必更换为强随机密钥
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# ===== App =====
# 对应 config.json → app.port
NEXT_PUBLIC_API_URL=http://localhost:4000
PORT=4000
